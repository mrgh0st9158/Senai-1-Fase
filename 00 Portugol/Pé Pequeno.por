programa {
  funcao inicio() {
    inteiro preco = 80
    real quantidade = 300.00
    real lucro_total= preco * quantidade

    escreva("O preço de cada calçado é equivalente R$: " + preco + ("\n e o preço a quantidade de pares trocados foi equivalente a: " + quantidade))

    escreva("\n")
    escreva("\nA loja teve um lucro total de R$: " + lucro_total + (" com vale-trocas.") )
  }
}

programa {
  funcao inicio() {
    inteiro laranja_I = 42
    inteiro laranja_F = 17
    inteiro laranja_V = laranja_I - laranja_F

    escreva("Tivemos " + laranja_I + " laranjas no ínicio do dia")
    escreva("\nPorém, ao fim do dia tivemos " + laranja_F + " laranjas.")

    escreva("\n")
    escreva("\nOu seja, vendemos " + laranja_V + " laranjas no dia.")
  }
}
